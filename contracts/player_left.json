{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "player_left.json",
  "title": "player_left",
  "description": "Emitted when a player leaves the multiplayer lobby",
  "allOf": [{ "$ref": "common.json#/$defs/eventMeta" }],
  "properties": {
    "event_type": { "const": "player_left" },
    "actor":      { "type": "integer" },
    "nick":       { "type": "string" }
  },
  "required": ["actor", "nick"]
}
