{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "set_track.json",
  "title": "set_track",
  "description": "Command sent from server to plugin to change the active track",
  "type": "object",
  "properties": {
    "cmd":         { "const": "set_track" },
    "command_id":  { "type": "string" },
    "env":         { "type": "string", "description": "Environment/scene name" },
    "track":       { "type": "string", "description": "Track name" },
    "race":        { "type": "string", "description": "Race mode" },
    "workshop_id": { "type": "string", "description": "Steam Workshop ID (empty for built-in tracks)" }
  },
  "required": ["cmd", "env", "track", "race"]
}
